{
  "name": "chamaeleon-browser",
  "version": "0.3.0",
  "description": "Webページを自分の使いやすい形へ変形し、操作を記録し、再訪問時に再現するカスタムブラウザ",
  "main": "dist-electron/main/main.js",
  "private": true,
  "scripts": {
    "dev": "vite dev & tsc -p tsconfig.electron.json --watch",
    "start": "npm run build && electron .",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "author": {
    "name": "Awokela",
    "email": "support@awokela.com"
  },
  "homepage": "https://awokela.com/products/chamaeleon-browser/"
}